# Dev Agent SSH Bridge Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: .env is excluded from git (see .gitignore) — never commit secrets.

# ===================
# Nginx Configuration
# ===================
NGINX_HTTP_PORT=8090        # Host port for HTTP dashboard (bound to localhost only)

# =====================
# Dashboard Authentication
# =====================
# Credentials for the web dashboard (basic auth)
# If not set, init_htpasswd.sh will generate a random password
DASHBOARD_USER=agent-dev
DASHBOARD_PASSWORD=         # Leave empty to auto-generate

# =====================
# SSH Chroot Settings
# =====================
AGENT_USER=dev-bot          # SSH user for the agent inside chroot
CHROOT_BASE=/srv/chroot/dev-bot  # Base chroot jail directory

# NOTE: Project directory permissions
# The jail_set.sh script automatically:
#   1. Adds AGENT_USER to the host user's group (from project_paths ownership)
#   2. Sets group-write permissions on project directories
# Prerequisite: project_paths should be owned by <host-user>:<host-group>
# If permissions fail, run manually:
#   sudo chown -R <user>:<group> /path/to/project
#   sudo chmod -R g+w /path/to/project

# ==========================
# Container Names (docker-compose)
# ==========================
AGENT_CONTAINER_NAME=agent-dev          # Main agent container name
NGINX_CONTAINER_NAME=agent-dev-nginx    # Nginx container name
AGENT_NETWORK_NAME=agent-dev-net        # Docker network name prefix

# ==========================
# Static IP Configuration
# ==========================
# These must match the IPs defined in docker-compose.yaml
# Used by firewall script for validation
EXPECTED_AGENT_IP=172.28.0.10           # Static IP for agent container
EXPECTED_NGINX_IP=172.28.0.20           # Static IP for nginx container
EXPECTED_PLAYWRIGHT_IP=172.28.0.40      # Static IP for Playwright browser container

# ==========================
# Playwright Browser Service
# ==========================
# The agent connects to Playwright via CDP on port 9222
# Set environment variable in your code:
#   PLAYWRIGHT_BROWSERS_SERVER=http://172.28.0.40:9222
# Or use the container name:
#   PLAYWRIGHT_BROWSERS_SERVER=http://playwright-browser:9222

# ==========================
# Container User IDs
# ==========================
# UIDs of the agent users inside each container image.
# Defaults match the official images — only change if you rebuild with different UIDs.
# Used by scripts/ssh_key/init_keys.sh to set correct ownership on .ssh/ and data dirs.
OPENCLAW_UID=1000       # openclaw container user (UID in ghcr.io/openclaw/openclaw)
CLAUDECODE_UID=1000     # node user in claudecode container
HERMES_UID=10000        # hermes user in nousresearch/hermes-agent

# ==========================
# Hermes Agent — LLM Provider Keys
# ==========================
# At least one of these is required when running AGENT=hermes-agent.
# Add your key here; docker-compose passes it into the container.
ANTHROPIC_API_KEY=            # Claude models (Opus, Sonnet, Haiku)
OPENROUTER_API_KEY=           # OpenRouter (access to many models)
OPENAI_API_KEY=               # OpenAI models

# ==========================
# Network Configuration (optional)
# ==========================
# Override Docker network subnet if needed to avoid conflicts:
# AGENT_SUBNET=172.28.0.0/24
# AGENT_GATEWAY=172.28.0.1
