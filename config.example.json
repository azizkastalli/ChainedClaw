{
  "allowed_domains": [
    "api.anthropic.com",
    "sentry.io",
    "statsig.anthropic.com",
    "statsig.com",
    "registry.npmjs.org",
    "pypi.org",
    "files.pythonhosted.org",
    "github.com",
    "api.github.com",
    "githubusercontent.com",
    "ghcr.io",
    "docker.io",
    "docker.com",
    "quay.io"
  ],
  "ssh_hosts": [
    {
      "name": "my-server",
      "hostname": "192.168.1.100",
      "port": 22,
      "user": "dev-bot",
      "strict_host_key_checking": true,
      "isolation": "container",
      "egress_filter": true,
      "docker_access": false,
      "project_paths": [
        "/path/to/your/project"
      ],
      "forward_ports": []
    },
    {
      "name": "my-dev-server",
      "hostname": "192.168.1.101",
      "port": 22,
      "user": "dev-bot",
      "strict_host_key_checking": true,
      "isolation": "container",
      "egress_filter": true,
      "docker_access": true,
      "project_paths": [
        "/path/to/your/project"
      ],
      "forward_ports": [3000, 8080]
    },
    {
      "name": "my-runpod",
      "hostname": "104.21.0.1",
      "port": 22022,
      "user": "dev-bot",
      "strict_host_key_checking": true,
      "isolation": "restricted_key",
      "project_paths": [
        "/workspace/my_project"
      ]
    }
  ]
}
